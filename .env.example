# Copy this file to `.env` and fill in real values.
#
# You must provide at least ONE of OPENROUTER_API_KEY or ANTHROPIC_API_KEY.
# OpenRouter is preferred when both are set (see src/llm/factory.py::get_provider).

OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=

# Model selection — the WRITER / PLANNER / ANALYZER all use the "general" model;
# the EDITOR (LLM-as-judge) uses a separate, typically stronger model.
#
# The values below are the defaults in src/config.py. Override here if you want
# to try different models (e.g. a faster/cheaper flash model for the writer,
# or a Claude model for the editor). Any OpenRouter or Anthropic model id works.

OPENROUTER_MODEL=anthropic/claude-sonnet-4-6
OPENROUTER_EDITOR_MODEL=google/gemini-3.1-pro-preview

ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_EDITOR_MODEL=claude-opus-4-7
